# Server Configuration
PORT=7777
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/elitehire?appName=EliteHire

# JWT Authentication
JWT_SECRET_KEY=your-strong-256-bit-secret-key-here

# Cloudinary (Image/File Uploads)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Gemini AI (Optional — falls back to local matcher if not set)
GEMINI_API_KEY=your_gemini_api_key

# CORS
CORS_ORIGIN=http://localhost:5173
